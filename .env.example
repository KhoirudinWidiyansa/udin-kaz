# Kas Keluarga - Environment Variables
# Salin file ini menjadi .env.local dan isi dengan nilai dari Vercel

# ─── Vercel Postgres ───────────────────────────────────────────────────────────
# Variabel-variabel ini OTOMATIS dibuat oleh Vercel saat kamu menghubungkan
# Postgres database ke project. Tarik ke lokal dengan:
#   npx vercel env pull .env.local
#
# Atau isi manual dari: Vercel Dashboard → Project → Storage → Connect → .env.local tab

POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://...?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NO_SSL="postgres://..."
POSTGRES_URL_NON_POOLING="postgres://..."
POSTGRES_USER="default"
POSTGRES_HOST="..."
POSTGRES_PASSWORD="..."
POSTGRES_DATABASE="verceldb"

# OCR struk via OpenAI Vision/Responses API (opsional)
# Jika tidak diisi, fitur Scan tetap bisa membuat draft dari teks OCR manual.
OPENAI_API_KEY=""
OPENAI_OCR_MODEL="gpt-4.1-mini"

# Draft mutasi bank via endpoint aggregator/internal (opsional)
# Jika tidak diisi, aplikasi memakai demo sandbox draft untuk menguji alur review.
BANK_DRAFTS_ENDPOINT=""
BANK_DRAFTS_TOKEN=""

# Konfigurasi Vercel AI SDK (Google Gemini)
GOOGLE_GENERATIVE_AI_API_KEY="ISI_API_KEY_GEMINI_ANDA_DI_SINI"
